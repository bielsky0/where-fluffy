# Szablon dla .env.production (gitignored — NIGDY nie commituj realnego pliku).
#
# Użycie:
#   cp .env.production.example .env.production
#   # wypełnij wartości poniżej
#   docker compose --env-file .env.production -f docker-compose.yml -f docker-compose.prod.yml up -d --build
#
# Zobacz DEPLOY.md po pełny runbook (prerekwizyty DNS, smoke test, znane ograniczenia).

# --- WYMAGANE ----------------------------------------------------------------
# docker-compose.prod.yml odmówi startu (${VAR:?...}), jeśli którejś z tych brakuje.

# Domena wskazująca DNS-em (A/AAAA) na ten host — Caddy użyje jej do automatycznego
# certyfikatu Let's Encrypt. DNS musi już działać PRZED pierwszym `up`, inaczej wystawienie
# certyfikatu się nie uda.
DOMAIN=

POSTGRES_USER=
# Ląduje bezpośrednio w connection stringu (postgresql://user:PASSWORD@host:port/db) w
# docker-compose.yml/docker-compose.prod.yml — bez URL-encodingu. `openssl rand -base64` może
# wylosować "/", "+" albo "=", które łamią parsowanie URL (Prisma/pg dostają błędny host/port).
# Użyj: openssl rand -hex 24  (tylko [0-9a-f], zawsze bezpieczne w URL-u).
POSTGRES_PASSWORD=
POSTGRES_DB=

# openssl rand -base64 48
# Nie może równać się 'super-secret-key-change-me' (src/shared/config/auth.config.ts
# wysadza proces na starcie, jeśli to wykryje w NODE_ENV=production).
JWT_SECRET=

# https://<DOMAIN> — musi być https, inaczej oauth.config.ts odmówi startu.
FRONTEND_URL=
# https://<DOMAIN>
BACKEND_PUBLIC_URL=

GF_SECURITY_ADMIN_USER=
GF_SECURITY_ADMIN_PASSWORD=

# Klucz API Resend — wymagany w produkcji, inaczej wysyłka kodów OTP mailem nie zadziała
# (src/shared/config/email.config.ts wysadza proces na starcie bez niego).
RESEND_API_KEY=

# Cloudinary (przechowywanie zdjęć zwierząt) — cloudinary.config.ts nie ma wartości domyślnych,
# więc proces wysadza się na starcie bez tych trzech. Wartości z panelu Cloudinary ("API
# Environment variable").
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- PODŁĄCZONE, OPCJONALNE ---------------------------------------------------
# Mają fallback w docker-compose.prod.yml (${VAR:-}) — bez nich compose wystartuje,
# ale odpowiadająca funkcja (logowanie przez dany provider) po prostu nie zadziała.

# Domyślnie WYŁĄCZONE w produkcji (docker-compose.prod.yml), niezależnie od pustych/wypełnionych
# ID/SECRET poniżej — ustaw jawnie "true" dopiero gdy zarejestrujesz apkę w Google Cloud
# Console / Meta for Developers z redirect URI https://<DOMAIN>/api/v1/auth/{google,facebook}/callback.
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_OAUTH_ENABLED=false
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Zaszywane w bundlu frontendu W MOMENCIE BUILDU obrazu `web` (Vite), nie odczytywane w
# runtime — zmiana wymaga `docker compose ... build web`, nie samego restartu.
# Domyślne '/api/v1' działa poprawnie za Caddy (ten sam origin) — zwykle zostaw puste.
VITE_API_BASE_URL=
# Zostaw puste, chyba że dodałeś w infra/caddy/Caddyfile publiczną trasę do Alloy —
# patrz DEPLOY.md, sekcja "Znane ograniczenia".
VITE_OTEL_EXPORTER_OTLP_ENDPOINT=

# Comma-separated allowlist adresów mailowych, które mogą wołać POST /pets/admin (content
# seeding). Puste = żadna trasa admina nieaktywna — to poprawny stan, nie błąd. Dopasowanie
# przeciwko już zalogowanemu req.user.email, bez osobnej roli/JWT claim.
ADMIN_EMAILS=

# Wymóg polityki użycia Nominatim/Photon (geokodowanie) — realny kontaktowy adres mailowy
# zamiast domyślnego placeholdera, zanim ruszy prawdziwy ruch.
NOMINATIM_USER_AGENT=
PHOTON_USER_AGENT=

# Domyślnie sandbox Resend (onboarding@resend.dev) — dostarcza wyłącznie na adres przypisany do
# Twojego konta Resend. Po zweryfikowaniu własnej domeny wysyłki (patrz panel Resend, sekcja
# "Domains") ustaw na adres z tej domeny, np. "Where's Fluffy <powiadomienia@pufik.pl>".
EMAIL_FROM_ADDRESS=

# --- ZDEFINIOWANE W KODZIE, ALE NIE PODŁĄCZONE PRZEZ COMPOSE -------------------
# Te zmienne mają Zod-owe defaulty w src/shared/config/*.config.ts, ale docker-compose.yml
# dziś w ogóle ich nie przekazuje do kontenera `api`/`ai-worker`. Ustawienie ich tutaj NIC
# NIE ZROBI, dopóki nie dodasz odpowiedniej linii do `environment:` w docker-compose.yml.
# LOG_LEVEL, EMBEDDING_*, FALLBACK_LOCATION_*
