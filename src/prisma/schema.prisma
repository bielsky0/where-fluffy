generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  extensions = [postgis]
}

model User {
  id          String     @id @default(uuid())
  email       String?    @unique
  password    String?
  phone       String?    @unique
  isGhost     Boolean    @default(false)
  name        String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relacje odwrotne (Prisma ich wymaga do mapowania)
  pets        Pet[]
  comments    Comment[]
  ownerChats  ChatRoom[] @relation("OwnerChats")
  finderChats ChatRoom[] @relation("FinderChats")
  messages    Message[]
}

// Kod OTP dla logowania bez hasła (ghost accounts). "identifier" to e-mail albo telefon podany
// przez użytkownika — rozłączony od User, bo w momencie żądania kodu konto może jeszcze nie
// istnieć (patrz auth.service.ts's verifyOtp / findOrCreateGhostUser).
model OtpCode {
  id         String   @id @default(uuid())
  identifier String
  code       String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([identifier])
}

model Pet {
  id                  String   @id @default(uuid())
  name                String
  species             String
  status              String   @default("missing")
  category            String   @default("other")
  reward              Int      @default(0) // Przywrócone pole reward
  phone               String?
  distinguishingMarks String?
  photoUrl            String?

  // Pole PostGIS
  location  Unsupported("geography(Point, 4326)")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  comments  Comment[]
  chats     ChatRoom[]

  @@index([location], type: Gist)
  @@index([category])
}

model Comment {
  id        String   @id @default(uuid())
  message   String
  type      String
  
  // Tutaj również warto zamienić na typ PostGIS
  location  Unsupported("geography(Point, 4326)")?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  petId     String
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model ChatRoom {
  id        String    @id @default(uuid())
  petId     String
  pet       Pet       @relation(fields: [petId], references: [id], onDelete: Cascade)
  
  ownerId   String
  owner     User      @relation("OwnerChats", fields: [ownerId], references: [id])
  finderId  String
  finder    User      @relation("FinderChats", fields: [finderId], references: [id])
  
  messages  Message[]
  createdAt DateTime  @default(now())

  @@unique([petId, ownerId, finderId])
}

model Message {
  id         String   @id @default(uuid())
  chatRoomId String
  chatRoom   ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  senderId   String
  sender     User     @relation(fields: [senderId], references: [id])
  text       String
  createdAt  DateTime @default(now())
}