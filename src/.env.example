DATABASE_URL="postgresql://user:password@localhost:5432/fluffy_db"
JWT_SECRET="replace-with-a-real-random-secret"
# Vite dev server, NOT :3000 — the OAuth callback redirects here, see auth.oauth.controller.ts.
FRONTEND_URL="http://localhost:5173"
REDIS_URL="redis://localhost:6379"
PORT=3000
NODE_ENV=development

OTEL_SERVICE_NAME="where-fluffy-api"
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4317"

FALLBACK_LOCATION_LAT=52.2297
FALLBACK_LOCATION_LNG=21.0122
FALLBACK_LOCATION_CITY="Warszawa"
GEOIP_DB_PATH="./geoip/GeoLite2-City.mmdb"

# OAuth — register each app first, redirect URIs must match exactly:
#   Google:   BACKEND_PUBLIC_URL + /api/v1/auth/google/callback
#   Facebook: BACKEND_PUBLIC_URL + /api/v1/auth/facebook/callback
BACKEND_PUBLIC_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Kill switch — set to "false" and restart the API to immediately stop new Google OAuth attempts
# (see shared/config/oauth.config.ts, auth.oauth.controller.ts) without a frontend redeploy.
GOOGLE_OAUTH_ENABLED="true"
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
FACEBOOK_OAUTH_ENABLED="true"

# Resend (email OTP) — only used when NODE_ENV=production, see auth.service.ts's requestOtp.
# In development the OTP code is logged to the console and echoed back as `devCode` instead.
RESEND_API_KEY=""
# Sandbox sender; only delivers to the Resend account's own verified address until a real
# sending domain is verified in the Resend dashboard.
EMAIL_FROM_ADDRESS="Where's Fluffy <onboarding@resend.dev>"

# Vector AI & Embedding Pipeline — self-hosted only, zero paid third-party AI APIs (no
# OPENAI_API_KEY or similar is introduced anywhere in this feature).
EMBEDDING_SERVICE_URL="http://localhost:11434"
# "fake" (default): deterministic hash-based vectors, zero network calls — safe default for
# dev/CI, exercises the whole pipeline (enqueue -> worker -> pgvector write -> search query)
# without needing Ollama running locally. Set to "local" to hit a real EMBEDDING_SERVICE_URL.
EMBEDDING_PROVIDER="fake"
