generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Deliberately NOT declaring "vector" here alongside "postgis" — this list drives
  // `prisma migrate`/`db push`'s automatic CREATE EXTENSION management, which runs against
  // every module's testcontainer DB, most of which use the bare postgis/postgis image without
  // pgvector installed (only pets/search's integration tests use the custom
  // where-fluffy/postgres-ai image, via a copied init script — see init-scripts/03-init-pgvector.sql).
  // Declaring "vector" here made `db push` try to enable it everywhere and broke every other
  // module's integration suite. Pet.embedding's Unsupported("vector(768)") type doesn't need the
  // extension declared here to parse — the hand-written migration's own
  // `CREATE EXTENSION IF NOT EXISTS "vector"` is what provisions it for real deployments.
  extensions = [postgis]
}

model User {
  id            String     @id @default(uuid())
  email         String?    @unique
  password      String?
  phone         String?    @unique
  isGhost       Boolean    @default(false)
  // OAuth (Google/Facebook) — patrz auth.repository.ts's findOrCreateOAuthUser. Oba pola razem
  // tworzą tożsamość dostawcy; NULL/NULL dla kont hasłowych i Ghost Account (OTP), więc
  // @@unique poniżej jest no-opem dla istniejących wierszy (Postgres pozwala na wiele NULL-i
  // w unikalnym indeksie).
  provider      String?
  providerId    String?
  // true dla kont OAuth (dostawca już zweryfikował e-mail) i dla Ghost Account po udanym
  // verifyOtp (odebranie kodu na e-mail też jest dowodem własności) — patrz auth.service.ts.
  emailVerified Boolean    @default(false)
  name          String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relacje odwrotne (Prisma ich wymaga do mapowania)
  pets        Pet[]
  comments    Comment[]
  ownerChats  ChatRoom[] @relation("OwnerChats")
  finderChats ChatRoom[] @relation("FinderChats")
  messages    Message[]

  @@unique([provider, providerId])
}

// Kod OTP dla logowania bez hasła (ghost accounts). Tylko e-mail (SMS nigdy nie jest wysyłany —
// patrz specyfikacja "Bezkosztowy, Jednolity System Autoryzacji") — rozłączony od User, bo w
// momencie żądania kodu konto może jeszcze nie istnieć (patrz auth.service.ts's verifyOtp /
// findOrCreateGhostUser).
model OtpCode {
  id        String   @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model Pet {
  id                  String   @id @default(uuid())
  // Opcjonalne: Znalazca nie zna imienia zwierzaka (Kreator V2, ścieżka "Znalazłem zwierzaka").
  name                String?
  species             String
  status              String   @default("missing")
  category            String   @default("other")
  reward              Int      @default(0) // Przywrócone pole reward
  phone               String?
  email               String?
  distinguishingMarks String?
  photoUrl            String?
  photoUrls           String[] @default([])
  city                String?

  // Pole PostGIS
  location  Unsupported("geography(Point, 4326)")?

  // Wektor embeddingu do wyszukiwania semantycznego (patrz Vector AI & Embedding Pipeline).
  // 768 wymiarów, żeby pasować do samohostowanego modelu nomic-embed-text (Ollama), nie do
  // OpenAI text-embedding-3-small (1536) — ten projekt nie korzysta z płatnych API AI stron
  // trzecich. Unsupported(...) z tego samego powodu co "location" powyżej: preview feature
  // postgresqlExtensions nie ma pierwszoklasowego wsparcia dla typu vector/indeksu HNSW, więc
  // wszystkie odczyty/zapisy idą przez surowe SQL (patrz pets.repository.ts / search.repository.ts).
  embedding Unsupported("vector(768)")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  comments  Comment[]
  chats     ChatRoom[]

  @@index([location], type: Gist)
  @@index([category])
  // Celowo brak @@index([embedding], ...) tutaj — enum IndexType Prismy (dla postgresqlExtensions)
  // nie zna wariantu Hnsw. Prawdziwy indeks (Pet_embedding_idx, USING hnsw) jest ręcznie zapisany
  // w surowym SQL migracji, patrz prisma/migrations/<timestamp>_add_pet_embedding_vector/.
}

model Comment {
  id        String   @id @default(uuid())
  message   String
  type      String
  
  // Tutaj również warto zamienić na typ PostGIS
  location  Unsupported("geography(Point, 4326)")?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  petId     String
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model ChatRoom {
  id        String    @id @default(uuid())
  petId     String
  pet       Pet       @relation(fields: [petId], references: [id], onDelete: Cascade)
  
  ownerId   String
  owner     User      @relation("OwnerChats", fields: [ownerId], references: [id])
  finderId  String
  finder    User      @relation("FinderChats", fields: [finderId], references: [id])
  
  messages  Message[]
  createdAt DateTime  @default(now())

  @@unique([petId, ownerId, finderId])
}

model Message {
  id         String   @id @default(uuid())
  chatRoomId String
  chatRoom   ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  senderId   String
  sender     User     @relation(fields: [senderId], references: [id])
  text       String
  createdAt  DateTime @default(now())
}